DJANGO_SECRET_KEY=troque-por-uma-chave-secreta-forte
DJANGO_DEBUG=0
VESTLINK_BASE_URL=https://vestlink.vercel.app

# Supabase > Project Settings > Database > Connection string > Transaction pooler > URI
# Troque [YOUR-PASSWORD] pela senha do banco do Supabase.
SUPABASE_DATABASE_URL=postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require

# Se conectar pelo Marketplace da Vercel com prefixo SUPABASE_,
# a variavel abaixo costuma ser criada automaticamente.
# SUPABASE_POSTGRES_URL=postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_ANON_KEY=sua-chave-anon-ou-publishable
SUPABASE_AUTH_EMAIL_CONFIRMATION=1
SUPABASE_EMAIL_REDIRECT_URL=https://vestlink.vercel.app/cadastro/supabase-confirmar/
# No Supabase, adicione esta URL em Authentication > URL Configuration > Redirect URLs:
# https://vestlink.vercel.app/cadastro/supabase-confirmar/
# Depois habilite Google em Authentication > Sign In / Providers.

# Recomendado para poolers/serverless.
DATABASE_CONN_MAX_AGE=0
DATABASE_DISABLE_SERVER_SIDE_CURSORS=1

# E-mail transacional para confirmacao de conta com Resend.
# Para enviar para clientes reais, use um dominio verificado no Resend.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=VestLink <noreply@seudominio.com.br>

# Pagamento Premium via Abacate Pay
ABACATE_PAY_API_KEY=ap_live_xxxxxxxxxxxxxxxxx
ABACATE_PAY_WEBHOOK_SECRET=gere-um-secret-forte
ABACATE_PAY_RETURN_URL=https://vestlink.vercel.app/painel/sua-loja/assinatura/
ABACATE_PAY_WEBHOOK_URL=https://vestlink.vercel.app/api/pagamentos/abacate-pay/webhook/
ABACATE_PAY_PREMIUM_PRODUCT_ID=prod_xxxxxxxxxxxxxxxxx

# Alternativa: SMTP tradicional.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.seuprovedor.com
EMAIL_PORT=587
EMAIL_USE_TLS=1
EMAIL_HOST_USER=usuario
EMAIL_HOST_PASSWORD=senha
DEFAULT_FROM_EMAIL=VestLink <contato@seudominio.com.br>

# Retencao/privacidade
LEAD_RETENTION_DAYS=365
SENTRY_SEND_DEFAULT_PII=0
